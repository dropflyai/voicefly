{
  "name": "VoiceFly — Appointment Reminders",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 1 }]
        }
      },
      "id": "node-schedule",
      "name": "Every Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ new Date().getHours() }}",
              "rightValue": 9,
              "operator": { "type": "number", "operation": "gte" }
            },
            {
              "id": "c2",
              "leftValue": "={{ new Date().getHours() }}",
              "rightValue": 17,
              "operator": { "type": "number", "operation": "lt" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "node-hours-check",
      "name": "9am–5pm?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.VOICEFLY_URL }}/api/cron/appointment-reminders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $vars.CRON_SECRET }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": { "timeout": 30000 }
      },
      "id": "node-http",
      "name": "Fire Reminder Calls",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 220]
    }
  ],
  "connections": {
    "Every Hour": {
      "main": [[{ "node": "9am–5pm?", "type": "main", "index": 0 }]]
    },
    "9am–5pm?": {
      "main": [[{ "node": "Fire Reminder Calls", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" }
}
